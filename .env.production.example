APP_NAME=Hablas
APP_ENV=production
APP_KEY=                          # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://hablas.thijssensoftware.nl
APP_TIMEZONE=Europe/Amsterdam
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=daily
LOG_LEVEL=warning

# SQLite, like tracker/id. The file must be owned deploy:www-data mode 664
# (see deploy/PROVISION.md) or php-fpm can't write it.
DB_CONNECTION=sqlite
DB_DATABASE=/home/deploy/hablas/database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
# Diverges from the other apps (they use false). Encrypted session+XSRF cookies
# are ~450B each, which pushes /login's response headers past nginx's 4k default
# and 502s — the vhost raises fastcgi_buffer_size to compensate. Keep both in
# sync if you change this.
SESSION_ENCRYPT=true

QUEUE_CONNECTION=database
CACHE_STORE=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ── Mail ─────────────────────────────────────────────────────────────────────
# Required for the daily digest (SendDailyDigests + DailyDigestNotification).
# Without a working mailer the scheduled digest silently fails.
# All apps on the droplet share one SMTP account; copy USERNAME/PASSWORD from a
# sibling app's .env (e.g. /home/deploy/tracker/.env). Port 465 is implicit TLS,
# so do NOT set MAIL_ENCRYPTION. Keep FROM_ADDRESS on the authenticated domain.
MAIL_MAILER=smtp
MAIL_HOST=mail.mijndomein.nl
MAIL_PORT=465
MAIL_USERNAME=                    # noreply@thijssensoftware.nl (shared)
MAIL_PASSWORD=                    # shared SMTP password
MAIL_FROM_ADDRESS="noreply@thijssensoftware.nl"
MAIL_FROM_NAME="Hablas"

# ── Google sign-in ───────────────────────────────────────────────────────────
# OAuth client at https://console.cloud.google.com/apis/credentials.
# Authorised redirect URI must be exactly the GOOGLE_REDIRECT_URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# ── Web Push (PWA notifications) ──────────────────────────────────────────────
# Generate once with: php artisan webpush:vapid (writes the pair; copy here).
# Rotating these invalidates every existing push subscription.
VAPID_SUBJECT="mailto:hablas@thijssensoftware.nl"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
