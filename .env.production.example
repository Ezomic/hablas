APP_NAME=Hablas
APP_ENV=production
APP_KEY=                          # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://hablas.thijssensoftware.nl
APP_TIMEZONE=Europe/Amsterdam
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=daily
LOG_LEVEL=warning

# SQLite, like tracker/id. The file must be owned deploy:www-data mode 664
# (see deploy/PROVISION.md) or php-fpm can't write it.
DB_CONNECTION=sqlite
DB_DATABASE=/home/deploy/hablas/database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

QUEUE_CONNECTION=database
CACHE_STORE=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ── Mail ─────────────────────────────────────────────────────────────────────
# Required for the daily/weekly digest (SendDailyDigests + DailyDigestNotification).
# Without a working mailer the scheduled digest silently fails.
MAIL_MAILER=smtp
MAIL_HOST=smtp.postmarkapp.com
MAIL_PORT=587
MAIL_USERNAME=                    # SMTP username / API token
MAIL_PASSWORD=                    # SMTP password / API token
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hablas@thijssensoftware.nl"
MAIL_FROM_NAME="${APP_NAME}"

# ── Google sign-in ───────────────────────────────────────────────────────────
# OAuth client at https://console.cloud.google.com/apis/credentials.
# Authorised redirect URI must be exactly the GOOGLE_REDIRECT_URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# ── Web Push (PWA notifications) ──────────────────────────────────────────────
# Generate once with: php artisan webpush:vapid (writes the pair; copy here).
# Rotating these invalidates every existing push subscription.
VAPID_SUBJECT="mailto:hablas@thijssensoftware.nl"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
